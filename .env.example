# ============================================================
# POC Gobernanza de Datos - Variables de entorno
# Copiar a .env y completar valores. NO commitear .env al repo.
# ============================================================

# Perfil AWS configurado en ~/.aws/credentials (o SSO)
AWS_PROFILE=poc-governance

# Region donde se desplegará la PoC (recomendado: us-east-1)
AWS_REGION=us-east-1

# Stage / entorno lógico (dev | qa | prod)
STAGE=dev

# Nombre corto del proyecto (usado como prefijo en todos los recursos)
PROJECT_NAME=poc-gov

# AWS Account ID de destino (12 dígitos)
CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=us-east-1

# ARN del rol que ejecuta `cdk deploy` (CDK exec role).
# Debe ser registrado como Data Lake Administrator ANTES del primer deploy.
CDK_EXEC_ROLE_ARN=arn:aws:iam::359469026769:role/poc-gov-cdk-deploy-role

# (Opcional) ARN de un rol "data-analyst" al que se le otorgará SELECT vía Lake Formation.
# Si se deja vacío, el construct lo creará.
DATA_ANALYST_ROLE_ARN=

# (Opcional) Email/usuario IAM Identity Center para acceso a DataZone (no requerido para PoC mínima)
DATAZONE_ADMIN_USER=
